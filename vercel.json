{
  "rewrites": [
    {
      "source": "/api/pvgis/:path*",
      "destination": "https://re.jrc.ec.europa.eu/api/v5_3/:path*"
    },
    {
      "source": "/api/eloverblik/:path*",
      "destination": "https://api.eloverblik.dk/customerapi/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
